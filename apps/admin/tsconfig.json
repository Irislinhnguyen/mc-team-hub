{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@query-stream-ai/auth": ["../../packages/auth"],
      "@query-stream-ai/config": ["../../packages/config"],
      "@query-stream-ai/db": ["../../packages/db"],
      "@query-stream-ai/types": ["../../packages/types"],
      "@query-stream-ai/ui": ["../../packages/ui"],
      "@query-stream-ai/utils": ["../../packages/utils"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../../packages/auth" },
    { "path": "../../packages/config" },
    { "path": "../../packages/db" },
    { "path": "../../packages/types" },
    { "path": "../../packages/ui" },
    { "path": "../../packages/utils" }
  ]
}
